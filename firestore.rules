rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users can only manage their own profile.
    match /users/{userId} {
      // Any authenticated user can create their own user document.
      // This is necessary for the registration flow.
      allow create: if request.auth != null;

      // A user can only read, update, or delete their own document.
      allow read, update, delete: if request.auth != null && request.auth.uid == userId;
    }

    // Public collections can be read by anyone, but not written to.
    match /blog/{postId} {
      allow read: if true;
      allow write: if false;
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;
    }

    match /faqs/{faqId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /quizSets/{quizId} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny all other reads/writes
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
